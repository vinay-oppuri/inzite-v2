{
  "name": "inzite",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev \"--filter=./apps/*\"",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "prettier": "^3.7.4",
    "turbo": "^2.10.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.5"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
